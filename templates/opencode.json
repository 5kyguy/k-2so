{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding/glm-5.2",
  "provider": {
    "zai-coding": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z.AI GLM Coding Plan",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "apiKey": "{env:ZAI_API_KEY}"
      },
      "models": {
        "glm-5.2": { "name": "GLM-5.2" },
        "glm-4.5-air": { "name": "GLM-4.5-Air" }
      }
    }
  },
  "agent": {
    "k2so": {
      "mode": "primary",
      "description": "K-2SO background companion",
      "prompt": "You are K-2SO, a direct background assistant. Complete the user's task using available tools. Write markdown reports to the task workspace when asked. Prefer MCP tools for system actions when available."
    }
  }
}
